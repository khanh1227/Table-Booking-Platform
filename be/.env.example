# Django Settings
# Generate a new secret key for production: https://djecrety.ir/
DJANGO_SECRET_KEY=django-insecure-dev-only-key-at-least-32-chars-long-123456789
DEBUG=True

# Database Settings (MySQL)
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=3306

# OpenAI Settings
OPENAI_API_KEY=your_openai_api_key

# VNPAY Settings (Sandbox)
VNPAY_TMN_CODE=your_vnp_tmn_code
VNPAY_HASH_SECRET=your_vnp_hash_secret
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=your_ngrok_or_server_url/api/payments/vnpay-ipn/
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_RETURN_URL_FE=http://localhost:5173/payment-result

# Other Config
BOOKING_AUTO_COMPLETE_AFTER_HOURS=2
PARTNER_SETTLEMENT_HOLD_HOURS=12
CUSTOMER_CANCEL_FULL_REFUND_HOURS=24
CUSTOMER_CANCEL_PARTIAL_REFUND_HOURS=2
CUSTOMER_CANCEL_PARTIAL_REFUND_RATE=0.5
PLATFORM_FEE_RATE=0.10
