**/__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# Django Specific
be/db.sqlite3
be/media/
be/staticfiles/
media/
staticfiles/

# Node / JS (Frontend & Mobile)
node_modules/
fe/dist/
fe/dist-ssr/
fe/build/
mobile/dist/
mobile/web-build/
.expo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.metro-health-check*
expo-env.d.ts
*.tsbuildinfo

# Native (Mobile)
mobile/
mobile/ios/
mobile/android/
.kotlin/

# Databases & Vector Stores
chroma_db/
*.sqlite3

# Logs
*.log
logs/

