# ── LLM Provider ─────────────────────────────────────────────────────────────
# Chọn 'ollama' hoặc 'google' , openai
LLM_PROVIDER=openai
GOOGLE_API_KEY=key_cua_ban
GOOGLE_MODEL=gemini-3.1-flash-lite-preview


OPENAI_API_KEY=key_cua_ban
OPENAI_MODEL=gpt-5.4-nano

# ── RAG Configuration ──────────────────────────────────────────────────────────
# Bật/Tắt việc tự động nạp dữ liệu (Embedding toàn bộ DB) khi startup và mỗi 6h.
# Nếu tắt (false), chatbot vẫn dùng dữ liệu cũ đã lưu trong chroma_db để search.
ENABLE_RAG_INGEST=false

# ── MySQL (cùng DB với Django) ─────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tablebooking_db_new
DB_USER=tb_user
DB_PASSWORD=123123123

# ── Django backend URL (dùng cho booking tạo mới cần auth) ────────────────────
BE_API_URL=http://127.0.0.1:8000

# ── Server ─────────────────────────────────────────────────────────────────────
CHATBOT_PORT=8001
